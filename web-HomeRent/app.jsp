// assets/app.jsconst API_BASE = location.origin + "/web-HomeRent/api";function saveToken(t) {    localStorage.setItem("ijarweb_token", t);    // تأمين الكوكي بـ SameSite و Secure إذا كان الموقع يستخدم HTTPS    document.cookie = `ijarweb_token=${encodeURIComponent(t)}; path=/web-HomeRent/; SameSite=Lax; Secure`;}function getToken() {    return localStorage.getItem("ijarweb_token") ||            document.cookie.match(/(?:^|;\s*)ijarweb_token=([^;]+)/)?.[1] || "";}function logout() {    localStorage.clear();    document.cookie = "ijarweb_token=; path=/web-HomeRent/; expires=Thu, 01 Jan 1970 00:00:00 GMT";    location.href = "/web-HomeRent/web/auth.php";}// دالة موحدة للتحكم في حالة الأزرار (Loading)function setLoading(btnId, isLoading) {    const btn = document.getElementById(btnId);    if (!btn) return;    if (isLoading) {        btn.disabled = true;        btn.dataset.originalText = btn.innerHTML;        btn.innerHTML = '<span class="spinner"></span> جاري المعالجة...';    } else {        btn.disabled = false;        btn.innerHTML = btn.dataset.originalText;    }}async function api(path, { method = "GET", body = null, isForm = false } = {}) {    const token = getToken();    const headers = { 'Accept': 'application/json' };        if (token) headers["Authorization"] = `Bearer ${token}`;    if (body && !isForm) headers["Content-Type"] = "application/json";    try {        const response = await fetch(API_BASE + path, {            method,            headers,            body: body && !isForm ? JSON.stringify(body) : body        });        const data = await response.json();        if (response.status === 401) {            logout();            throw new Error("انتهت الجلسة، يرجى تسجيل الدخول مجدداً");        }        if (!response.ok || !data.ok) {            throw new Error(data.message || "حدث خطأ في النظام");        }        return data;    } catch (e) {        console.error("API Error:", e);        throw e;    }}